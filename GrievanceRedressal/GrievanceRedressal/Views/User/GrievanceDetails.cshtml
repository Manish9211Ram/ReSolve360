@model GrievanceRedressal.Models.Grievance
@{
    ViewData["Title"] = @Localizer["Details"];
}

<div class="container mt-5">
    <div class="row">
        <div class="col-md-8 mx-auto">
            <div class="card shadow border-0">
                <div class="card-header bg-dark text-white">
                    <h5 class="mb-0">@Localizer["ProgressTimeline"]</h5>
                </div>
                <div class="card-body p-4">
                    <h4 class="fw-bold">@Model.Title</h4>
                    <p class="text-muted small">@Localizer["TicketID"]: #GR-@Model.GrievanceId | @Localizer["Description"]: @Model.Description</p>
                    
                    @if (!string.IsNullOrEmpty(Model.AttachmentPath))
                    {
                        <div class="mt-3 mb-4 text-center">
                            <h6 class="text-muted text-start mb-2"><i class="bi bi-paperclip"></i> @Localizer["Attachment"]</h6>
                            <img src="@Model.AttachmentPath" class="img-fluid rounded border shadow-sm" style="max-height: 300px; cursor: pointer;" onclick="window.open(this.src)" />
                        </div>
                    }
                    <hr />

                    <div class="mt-4">
                        <div class="d-flex mb-4">
                            <div class="text-success me-3"><i class="bi bi-check-circle-fill"></i> @Localizer["Done"]</div>
                            <div>
                                <strong>@Localizer["GrievanceSubmitted"]</strong><br />
                                <small class="text-muted">@Model.CreatedAt.ToString("f")</small>
                            </div>
                        </div>
                        
                        @if(Model.StatusId >= 2) {
                            <div class="d-flex mb-4">
                                <div class="text-primary me-3"><i class="bi bi-clock-fill"></i> @Localizer["Active"]</div>
                                <div>
                                    <strong>@Localizer["AssignedAndInProgress"]</strong><br />
                                    <small class="text-muted">@Localizer["InvestigatingIssue"]</small>
                                </div>
                            </div>
                        } else {
                            <div class="d-flex mb-4 opacity-50">
                                <div class="text-secondary me-3"><i class="bi bi-circle"></i> @Localizer["Pending"]</div>
                                <div>
                                    <strong>@Localizer["AssignedAndInProgress"]</strong><br />
                                    <small class="text-muted">@Localizer["AwaitingAssignment"]</small>
                                </div>
                            </div>
                        }

                        @if(Model.StatusId == 3) {
                            <div class="d-flex mb-4">
                                <div class="text-success me-3"><i class="bi bi-check-circle-fill"></i> @Localizer["Resolved"]</div>
                                <div>
                                    <strong>@Localizer["ResolutionCompleted"]</strong><br />
                                    <small class="text-success">@Localizer["IssueSolved"]</small>
                                </div>
                            </div>
                        } else {
                            <div class="d-flex mb-4 opacity-50">
                                <div class="text-secondary me-3"><i class="bi bi-circle"></i> @Localizer["Pending"]</div>
                                <div>
                                    <strong>@Localizer["ResolutionCompleted"]</strong><br />
                                    <small class="text-muted">@Localizer["ExpectedSoon"]</small>
                                </div>
                            </div>
                        }
                    </div>

                    <a href="/User/MyGrievances" class="btn btn-outline-secondary mt-3 hover-lift">@Localizer["BackToList"]</a>
                </div>
            </div>
        </div>
    </div>
</div>

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">