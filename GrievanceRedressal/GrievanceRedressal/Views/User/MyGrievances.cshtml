@model IEnumerable<GrievanceRedressal.Models.Grievance>
@{
    ViewData["Title"] = Localizer["MyGrievances"];
}

<div class="container mt-4">
    <div class="card shadow border-0">
        <div class="card-header bg-primary text-white py-3">
            <h4 class="mb-0">@Localizer["MyComplaintList"]</h4>
        </div>
        <div class="card-body">
            <div class="table-responsive">
                <table class="table table-hover align-middle">
                    <thead class="table-light">
                        <tr>
                            <th>@Localizer["TicketID"]</th>
                            <th>@Localizer["Subject"]</th>
                            <th>@Localizer["Status"]</th>
                            <th>@Localizer["Action"]</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model != null && Model.Any())
                        {
                            foreach (var item in Model)
                            {
                                <tr>
                                    <td>#GR-@item.GrievanceId</td>
                                    <td>@item.Title</td>
                                    <td>
                                        @if(item.StatusId == 1) { <span class="badge bg-secondary animate-pulse">@Localizer["OpenStatus"]</span> }
                                        else if (item.StatusId == 2) { <span class="badge bg-warning text-dark">@Localizer["InProgressStatus"]</span> }
                                        else if (item.StatusId == 3) { <span class="badge bg-success">@Localizer["ResolvedStatus"]</span> }
                                    </td>
                                    <td>
                                        <a href="/User/GrievanceDetails/@item.GrievanceId" class="btn btn-sm btn-outline-primary shadow-sm hover-lift">@Localizer["ViewDetails"]</a>
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr><td colspan="4" class="text-center text-muted">@Localizer["NoGrievancesFound"]</td></tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>