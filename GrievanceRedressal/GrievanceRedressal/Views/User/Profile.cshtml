@{
    ViewData["Title"] = @Localizer["MyProfile"];
}

<style>
    .glass-profile-card {
        background: rgba(255, 255, 255, 0.1);
        backdrop-filter: blur(20px);
        border: 1px solid rgba(255, 255, 255, 0.2);
        border-radius: 25px;
        padding: 40px;
        color: white;
        box-shadow: 0 15px 35px rgba(0,0,0,0.2);
    }
</style>

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-lg-6">
            <div class="glass-profile-card shadow-lg text-center animate-fade-in-up">
                
                <div class="bg-primary text-white rounded-circle d-inline-flex align-items-center justify-content-center mb-4 shadow-lg profile-avatar"
                     style="width: 120px; height: 120px; font-size: 3rem; font-weight: bold; border: 4px solid rgba(255,255,255,0.2);">
                    @(User.Identity.IsAuthenticated && !string.IsNullOrEmpty(User.Identity.Name) ? User.Identity.Name.Substring(0, 1).ToUpper() : "U")
                </div>

                <h2 class="fw-bold mb-1 header-style text-white">@(User.Identity.Name ?? Localizer["UnknownUser"].Value)</h2>
                <span class="badge bg-info text-dark rounded-pill px-3 py-2 mb-4">
                    <i class="bi bi-shield-check me-1"></i> @User.Claims.FirstOrDefault(c => c.Type == System.Security.Claims.ClaimTypes.Role)?.Value
                </span>

                <div class="text-start mt-4 px-3">
                    <div class="mb-3 border-bottom border-light border-opacity-10 pb-2">
                        <small class="text-white-50 text-uppercase fw-bold"><i class="bi bi-envelope me-2"></i>@Localizer["EmailAddress"]</small>
                        <p class="fs-5 mb-0 text-white">@User.Claims.FirstOrDefault(c => c.Type == System.Security.Claims.ClaimTypes.Email)?.Value</p>
                    </div>

                    <div class="mb-3 border-bottom border-light border-opacity-10 pb-2">
                        <small class="text-white-50 text-uppercase fw-bold"><i class="bi bi-person-badge me-2"></i>@Localizer["AccountID"]</small>
                        <p class="fs-5 mb-0 text-white">@User.Claims.FirstOrDefault(c => c.Type == System.Security.Claims.ClaimTypes.NameIdentifier)?.Value</p>
                    </div>
                </div>

                <div class="mt-5">
                    <a href="/User/Dashboard" class="btn btn-outline-light rounded-pill px-4 me-2">@Localizer["BackToDashboard"]</a>
                    <a href="/Account/Logout" class="btn btn-danger rounded-pill px-4 shadow-sm"><i class="bi bi-power me-2"></i>@Localizer["Logout"]</a>
                </div>
            </div>
        </div>
    </div>
</div>
