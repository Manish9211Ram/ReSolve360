@using Microsoft.AspNetCore.Mvc.Localization
@inject IViewLocalizer Localizer
@{
    ViewData["Title"] = "Forgot Password";
    Layout = "_Layout";
}
<div class="auth-wrapper">
    <div class="x-container" style="height: auto; padding: 40px; width: 500px;">
        <form asp-controller="Account" asp-action="ForgotPassword" method="post" class="x-form p-0" style="background: transparent;">
            <h1 class="mb-2">@(ViewBag.IsReset == true ? Localizer["ResetPassword"] : Localizer["ForgotPassword"])</h1>
            <p class="text-white opacity-75 mb-4">@(ViewBag.IsReset == true ? Localizer["EnterNewPass"] : Localizer["EnterRegisteredEmail"])</p>
            
            @if(ViewBag.Message != null) {
                <div class="alert alert-info py-2 small" style="background: rgba(0, 242, 254, 0.1); border-color: var(--accent-pink); color: white;">
                    <i class="bi bi-info-circle me-1"></i> @ViewBag.Message
                </div>
            }

            @* Always keep email as a hidden field if we are in Step 2, so it's guaranteed to be posted *@
            @if(ViewBag.IsReset == true) {
                <input type="hidden" name="email" value="@ViewBag.Email" />
                <div class="x-input-group mt-3 opacity-75">
                    <input type="email" class="x-input" value="@ViewBag.Email" readonly disabled />
                    <i class="bi bi-envelope text-white"></i>
                </div>
            } else {
                <div class="x-input-group mt-3">
                    <input type="email" name="email" class="x-input" placeholder="@Localizer["EnterEmail"]" required />
                    <i class="bi bi-envelope text-white"></i>
                </div>
            }

            @if(ViewBag.IsReset == true) {
                <div class="x-input-group mt-3">
                    <input type="password" name="password" class="x-input" placeholder="@Localizer["NewPassword"]" required />
                    <i class="bi bi-lock text-white"></i>
                </div>
                <div class="x-input-group mt-3">
                    <input type="password" name="confirmPassword" class="x-input" placeholder="@Localizer["ConfirmPassword"]" required />
                    <i class="bi bi-lock text-white"></i>
                </div>
            }
            
            <button class="x-btn shadow mt-3 w-100" type="submit">@(ViewBag.IsReset == true ? Localizer["UpdatePasswordButton"] : Localizer["VerifyEmailButton"])</button>
            
            <div class="switch-text mt-4">
                @Localizer["SuddenlyRemembered"] <a asp-controller="Account" asp-action="Login">@Localizer["BackToLogin"]</a>
            </div>
        </form>
    </div>
</div>
