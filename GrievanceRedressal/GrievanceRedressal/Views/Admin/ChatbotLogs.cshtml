@model IEnumerable<GrievanceRedressal.Models.ChatbotLog>
@{
    ViewData["Title"] = "Chatbot Logs";
}

<style>
    .glass-card {
        background: rgba(255, 255, 255, 0.05);
        backdrop-filter: blur(15px);
        border: 1px solid rgba(255, 255, 255, 0.1);
        border-radius: 20px;
        color: white;
    }

    .table {
        color: rgba(255, 255, 255, 0.85);
    }

    .table thead th {
        border-bottom: 1px solid rgba(255, 255, 255, 0.2);
        color: #00f2fe;
        font-weight: 600;
        text-transform: uppercase;
        font-size: 0.8rem;
        letter-spacing: 1px;
    }

    .table td {
        border-bottom: 1px solid rgba(255, 255, 255, 0.05);
        vertical-align: middle;
        font-size: 0.9rem;
    }

    .session-badge {
        font-family: monospace;
        background: rgba(0, 242, 254, 0.1);
        color: #00f2fe;
        padding: 4px 8px;
        border-radius: 6px;
        font-size: 0.75rem;
    }

    .user-pill {
        background: rgba(255, 255, 255, 0.1);
        padding: 2px 10px;
        border-radius: 20px;
        font-size: 0.8rem;
    }

    .log-message {
        max-width: 300px;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
    }

    .log-message:hover {
        white-space: normal;
        background: rgba(255,255,255,0.05);
        border-radius: 5px;
        padding: 5px;
        position: absolute;
        z-index: 10;
        max-width: 400px;
        box-shadow: 0 10px 30px rgba(0,0,0,0.5);
    }
</style>

<div class="row animate-slide-in-right">
    <div class="col-12 mb-4 d-flex justify-content-between align-items-center">
        <div>
            <h2 class="fw-bold mb-0" style="font-family: 'Righteous', sans-serif; text-shadow: 0 0 15px rgba(0, 242, 254, 0.4);">
                <i class="bi bi-robot me-2 text-info"></i> Chatbot Interaction Logs
            </h2>
            <p class="text-white-50 small mb-0">Monitor all AI assistant conversations across the platform</p>
        </div>
        <div>
            <a href="/Admin/Index" class="btn btn-outline-light btn-sm rounded-pill px-3">
                <i class="bi bi-arrow-left me-1"></i> Back to Dashboard
            </a>
        </div>
    </div>

    <div class="col-12">
        <div class="card glass-card shadow-lg border-0 overflow-hidden">
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-hover mb-0">
                        <thead>
                            <tr>
                                <th class="ps-4">Time</th>
                                <th class="text-center">User ID</th>
                                <th>Session ID</th>
                                <th>User Query</th>
                                <th>Suggested Category</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (Model == null || !Model.Any())
                            {
                                <tr>
                                    <td colspan="5" class="text-center py-5 text-white-50">
                                        <i class="bi bi-inbox fs-1 d-block mb-2 opacity-25"></i>
                                        No chatbot logs found yet.
                                    </td>
                                </tr>
                            }
                            else 
                            {
                                @foreach (var log in Model)
                                {
                                    <tr>
                                        <td class="ps-4 small">
                                            <span class="text-white">@log.CreatedAt.ToString("HH:mm:ss")</span>
                                            <div class="text-white-50" style="font-size: 0.7rem;">@log.CreatedAt.ToString("dd MMM yyyy")</div>
                                        </td>
                                        <td class="text-center">
                                            <div class="user-pill d-inline-block">
                                                <i class="bi bi-person-fill me-1"></i> @(log.UserId.HasValue ? $"ID: {log.UserId}" : "Guest")
                                            </div>
                                        </td>
                                        <td><span class="session-badge">@log.SessionId</span></td>
                                        <td><div class="log-message" title="@log.Query">@log.Query</div></td>
                                        <td>
                                            <span class="badge rounded-pill @(log.SuggestedCategory == "Technical" ? "bg-danger" : 
                                                                              log.SuggestedCategory == "Hostel" ? "bg-warning" : 
                                                                              log.SuggestedCategory == "Academic" ? "bg-primary" : "bg-info")" style="font-size: 0.7rem;">
                                                @log.SuggestedCategory
                                            </span>
                                        </td>
                                    </tr>
                                }
                            }
                        </tbody>
                    </table>
                </div>
            </div>
            <div class="card-footer bg-transparent border-top border-white border-opacity-10 py-3">
                <div class="d-flex justify-content-between align-items-center small text-white-50">
                    <span>Showing @Model.Count() recent interactions</span>
                    <span><i class="bi bi-info-circle me-1"></i> Hover over messages to see full text</span>
                </div>
            </div>
        </div>
    </div>
</div>
